{
  "name": "@pro2/my-app-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "my-app-e2e",
    "implicitDependencies": [
      "my-app"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/my-app-e2e/jest.config.ts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "my-app:build"
        ]
      }
    }
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "supertest": "^7.1.3"
  }
}
